"General settings-------------------------
if !&compatible
  set nocompatible
endif

syntax on
colorscheme ron
filetype plugin indent on

set encoding=utf-8
set fileencoding=utf-8
set fileencodings=utf-8,cp932,sjis,euc-jp
set display=uhex
set mouse=a
set ttymouse=sgr
set t_ut=
set visualbell t_vb=
set wildignorecase
set wildmenu
set tildeop
set hidden
set autoread
set lazyredraw
set noswapfile
set nowritebackup


"UI settings------------------------------
set splitbelow
set splitright
set cursorline
set cursorcolumn
set nostartofline
set showcmd
set title
set number
set ruler
set list
set listchars=tab:▸\ ,eol:↲,extends:❯,precedes:❮
set scrolloff=5
set showtabline=2
set laststatus=2
set statusline=%<%f\ %m%r%h%w%y%{'['.(&fenc!=''?&fenc:&enc).']['.&ff.']'}%=%4v\ %l/%L


"Search settings--------------------------
set ignorecase
set smartcase
set incsearch
set hlsearch
set nowrapscan
set history=1000


"Bracket settings-------------------------
set showmatch
set matchpairs=(:),{:},[:],<:>
set matchtime=3


"Indent settings--------------------------
set autoindent
set expandtab
set tabstop=2
set shiftwidth=2

if (v:version == 704 && has('patch338')) || v:version >=705
  set breakindent
endif


"Key binding settings---------------------
nnoremap <silent>,su :w !sudo tee %<CR>
nnoremap <silent><ESC><ESC> :noh<CR>
nnoremap <silent><C-n> :new<CR>
nnoremap <silent><C-w>h :sp<CR>
nnoremap <silent><C-w>v :vsp<CR>
nnoremap <silent><S-n> :tabnew<CR>
nnoremap <silent><S-Left> :tabprev<CR>
nnoremap <silent><S-Right> :tabnext<CR>
nnoremap <C-w>oh :sp<space>
nnoremap <C-w>ov :vsp<space>
nnoremap <C-o> :o<space>

function Show_state(name)
  echohl Title
  if eval('&' . a:name) || eval('&' . a:name) != ''
    echomsg '*** Toggled ' . a:name . ' to true ***'
  else
    echomsg '*** Toggled ' . a:name . ' to false ***'
  endif
  echohl None
endfunction

function Tab_switch()
  if &expandtab
    set noexpandtab
  else
    set expandtab
  endif
  call Show_state('expandtab')
endfunction
nnoremap <silent><S-TAB> :call Tab_switch()<CR>

function Wrap_switch()
  if &wrap
    set nowrap
  else
    set wrap
  endif
  call Show_state('wrap')
endfunction
nnoremap <silent><ESC>w :call Wrap_switch()<CR>

function Mouse_switch()
  if &mouse == 'a'
    set mouse=
  else
    set mouse=a
  endif
  call Show_state('mouse')
endfunction
nnoremap <silent><ESC>m :call Mouse_switch()<CR>
