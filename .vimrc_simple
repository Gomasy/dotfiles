"General settings-------------------------
if !&compatible
  set nocompatible
endif

syntax on
colorscheme ron
filetype plugin indent on

set encoding=utf-8
set fileencoding=utf-8
set fileencodings=utf-8,cp932,sjis,euc-jp
set nrformats=alpha,bin,hex
set display=uhex
set mouse=a
set ttymouse=sgr
set t_ut=
set visualbell t_vb=
set wildignorecase
set wildmenu
set tildeop
set hidden
set autoread
set lazyredraw
set noswapfile
set nowritebackup


"UI settings------------------------------
set splitbelow
set splitright
set cursorline
set cursorcolumn
set nostartofline
set showcmd
set title
set number
set ruler
set list
set listchars=tab:▸\ ,eol:↲,extends:❯,precedes:❮
set scrolloff=5
set showtabline=2
set laststatus=2
set statusline=%<%f\ %m%r%h%w%y%{'['.(&fenc!=''?&fenc:&enc).']['.&ff.']'}%=%4v\ %l/%L


"Search settings--------------------------
set ignorecase
set smartcase
set incsearch
set hlsearch
set nowrapscan
set history=1000


"Bracket settings-------------------------
set showmatch
set matchpairs=(:),{:},[:],<:>
set matchtime=3


"Indent settings--------------------------
set autoindent
set expandtab
set tabstop=2
set shiftwidth=2

if has('breakindent')
  set breakindent
endif


"Key binding settings---------------------
nnoremap <silent>,su :w !sudo tee %<CR>
nnoremap <silent>,r :source ~/.vim/vimrc<CR>
nnoremap <silent><ESC><ESC> :noh<CR>
nnoremap <silent><C-n> :new<CR>
nnoremap <silent><C-w>h :sp<CR>
nnoremap <silent><C-w>v :vsp<CR>
nnoremap <silent><S-n> :tabnew<CR>
nnoremap <silent><S-TAB> :tabprev<CR>
nnoremap <silent><TAB> :tabnext<CR>
nnoremap <C-w>oh :sp<space>
nnoremap <C-w>ov :vsp<space>
nnoremap <C-o> :o<space>

"Disable allow keys
noremap <Left> <Nop>
noremap <Down> <Nop>
noremap <Up> <Nop>
noremap <Right> <Nop>
inoremap <Left> <Nop>
inoremap <Down> <Nop>
inoremap <Up> <Nop>
inoremap <Right> <Nop>

"Window settings
nnoremap <Left> <C-w>h
nnoremap <Down> <C-w>j
nnoremap <Up> <C-w>k
nnoremap <Right> <C-w>l
nnoremap <S-Up> <C-w>+
nnoremap <S-Down> <C-w>-
nnoremap <S-Left> <C-w><
nnoremap <S-Right> <C-w>>

"Toggle options
function! Toggle_state(name)
  echohl Title
  if eval('&' . a:name) || eval('&' . a:name) != ''
    if a:name == 'mouse' | set mouse= | else | exec 'set no' . a:name | endif
    echo '*** Toggled ' . a:name . ' to false ***'
  else
    if a:name == 'mouse' | set mouse=a | else | exec 'set ' . a:name | endif
    echo '*** Toggled ' . a:name . ' to true ***'
  endif
  echohl None
endfunction

nnoremap <silent><ESC>m :call Toggle_state('mouse')<CR>
nnoremap <silent><ESC>n :call Toggle_state('relativenumber')<CR>
nnoremap <silent><ESC>t :call Toggle_state('expandtab')<CR>
nnoremap <silent><ESC>w :call Toggle_state('wrap')<CR>
